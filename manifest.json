{
  "manifest_version": 3,
  "name": "TokenLens",
  "version": "0.1.0",
  "description": "See what AI actually sees when it reads your webpage — token counts at every stage of the extraction pipeline.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "TokenLens"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
