{
  "manifest_version": 3,
  "name": "TokenLens",
  "version": "0.2.0",
  "description": "See what AI actually sees when it reads your webpage — token counts at every stage of the extraction pipeline.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "TokenLens"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-Xigk8Z6W.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/content-script.ts-Xigk8Z6W.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
